---
export const prerender = true;
import { sanityClient } from '@lib/sanity';
import { urlFor } from '@lib/imageUrl';
import Layout from '@theme/layouts/Layout.astro';
import CTASection from '@theme/components/CTASection.astro';

const posts = await sanityClient.fetch(
  `*[_type == "post"] | order(date desc) { title, "slug": slug.current, date, excerpt, coverImage }`
);
---

<Layout title="Blog" description="Health tips and insights from our team.">
  <div class="bg-brand-deeper text-white py-16 px-4 text-center">
    <h1 class="text-4xl font-serif">From the Blog</h1>
    <p class="mt-3 text-stone-300 text-lg">Health tips and practice news</p>
  </div>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      {posts.length === 0 ? (
        <p class="text-center text-stone-400 py-16">Blog posts coming soon.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {posts.map((post: any) => {
            const formatted = new Date(post.date).toLocaleDateString('en-NZ', { year: 'numeric', month: 'long', day: 'numeric' });
            return (
              <a href={`/blog/${post.slug}/`} class="group block bg-white border border-stone-200 rounded-lg overflow-hidden hover:shadow-md transition-shadow">
                {post.coverImage?.asset && (
                  <div class="aspect-[16/9] overflow-hidden">
                    <img
                      src={urlFor(post.coverImage).width(640).height(360).fit('crop').auto('format').url()}
                      alt={post.coverImage.alt ?? post.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                      width="640"
                      height="360"
                    />
                  </div>
                )}
                <div class="p-6">
                  <p class="text-xs text-stone-400 mb-2">{formatted}</p>
                  <h2 class="font-serif text-lg text-brand-deeper mb-2 group-hover:underline">{post.title}</h2>
                  {post.excerpt && <p class="text-stone-600 text-sm leading-relaxed">{post.excerpt}</p>}
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <CTASection />
</Layout>

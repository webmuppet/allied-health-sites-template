---
export const prerender = true;
import { sanityClient } from '../lib/sanity';
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';

const sorted = await sanityClient.fetch(
  `*[_type == "teamMember"] | order(order asc) { displayName, "slug": slug.current, title, headshot }`
);
---

<Layout title="Meet the Team" description="Meet our experienced team of allied health practitioners.">
  <div class="bg-brand-deeper text-white py-16 px-4 text-center">
    <h1 class="text-4xl font-serif">Meet the Team</h1>
    <p class="mt-3 text-stone-300 text-lg">Experienced, caring practitioners</p>
  </div>

  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {sorted.map((member: any) => (
          <a href={`/${member.slug}/`} class="group block bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition-shadow border border-stone-100">
            {member.headshot && (
              <div class="aspect-[4/3] overflow-hidden bg-warm-gray">
                <img
                  src={member.headshot}
                  alt={`${member.displayName}, ${member.title}`}
                  class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-5">
              <h2 class="font-serif text-lg text-brand-deeper mb-1">{member.displayName}</h2>
              <p class="text-stone-500 text-sm">{member.title}</p>
              <span class="inline-block mt-3 text-brand text-sm font-medium group-hover:underline">Read bio →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>

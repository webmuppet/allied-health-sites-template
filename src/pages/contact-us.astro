---
export const prerender = true;
import Layout from '@theme/layouts/Layout.astro';
import CTASection from '@theme/components/CTASection.astro';
import { sanityClient } from '@lib/sanity';

let settings: any = {};
try {
  settings = await sanityClient.fetch(
    `*[_type == "siteSettings"][0]{ practiceName, phone, phoneHref, email, address, suburb, postcode, googleMaps, bookingUrl }`
  );
} catch {}
---

<Layout title="Contact Us" description="Get in touch with our practice.">
  <div class="bg-brand-deeper text-white py-16 px-4 text-center">
    <h1 class="text-4xl font-serif">Contact Us</h1>
    <p class="mt-3 text-stone-300 text-lg">We'd love to hear from you</p>
  </div>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">

      <div class="space-y-6">
        <h2 class="font-serif text-2xl text-brand-deeper">Get in Touch</h2>

        {settings?.phone && (
          <div>
            <p class="text-xs uppercase tracking-wider text-stone-400 mb-1">Phone</p>
            <a href={settings.phoneHref ?? `tel:${settings.phone}`} class="text-brand-dark font-medium hover:underline text-lg">
              {settings.phone}
            </a>
          </div>
        )}

        {settings?.email && (
          <div>
            <p class="text-xs uppercase tracking-wider text-stone-400 mb-1">Email</p>
            <a href={`mailto:${settings.email}`} class="text-brand-dark font-medium hover:underline">
              {settings.email}
            </a>
          </div>
        )}

        {settings?.address && (
          <div>
            <p class="text-xs uppercase tracking-wider text-stone-400 mb-1">Address</p>
            <p class="text-stone-700 leading-relaxed">
              {settings.address}<br />
              {settings.suburb}{settings.postcode ? `, ${settings.postcode}` : ''}
            </p>
          </div>
        )}

        {settings?.bookingUrl && (
          <div class="pt-4">
            <a
              href={settings.bookingUrl}
              class="inline-block bg-brand text-white px-6 py-3 rounded-md font-medium hover:bg-brand-dark transition-colors"
            >
              Book an Appointment
            </a>
          </div>
        )}

        {!settings?.phone && !settings?.email && !settings?.address && (
          <p class="text-stone-400 italic">Contact details will appear here once configured in Sanity.</p>
        )}
      </div>

      {settings?.googleMaps && (
        <div class="rounded-lg overflow-hidden border border-stone-200 h-80 md:h-auto">
          <iframe
            src={settings.googleMaps}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Practice location map"
          />
        </div>
      )}

      {!settings?.googleMaps && (
        <div class="rounded-lg bg-warm-gray border border-stone-200 h-64 md:h-auto flex items-center justify-center">
          <p class="text-stone-400 text-sm italic">Map will appear once configured in Sanity.</p>
        </div>
      )}

    </div>
  </section>

  <CTASection />
</Layout>
